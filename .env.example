# Örnek ortam değişkenleri (şablon). Gerçek sırları asla depoya commit etmeyin.
# Yerel çalışma: dosyayı `.env` olarak kopyalayın (git ignore) veya PowerShell’de $env:... ile verin.
# Bu repodaki Docker Compose PostgreSQL şifresi `turizim_dev_password` — backend’e aynı değeri geçmelisiniz.
DB_URL=jdbc:postgresql://localhost:5432/turizim
DB_USERNAME=turizim
DB_PASSWORD=change_me_for_local_only
