# Tur İzim — Ortam Değişkeni Şablonu
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin.
# .env dosyası .gitignore ile hariç tutulmuştur — asla Git'e eklemeyin.
#
# Kullanım (PowerShell):
#   cp .env.example .env
#   # .env dosyasını düzenleyin
#
# Kullanım (Docker Compose):
#   docker compose --env-file .env up -d

# ── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/turizim
POSTGRES_USER=turizim
POSTGRES_PASSWORD=

# ── Spring Boot uygulama ayarları ─────────────────────────────────────────
# Geliştirme ortamı için true; üretimde false yapın
APP_DEV_SEED=true
# Geliştirme ortamı için true; üretimde false yapın (JWT zorunlu olur)
APP_LEGACY_OPEN_API=true

# ── AI servisi (OpenRouter) ───────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# TODO: Üretimde OpenRouter referans URL'si eklenebilir
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Frontend / Flutter ────────────────────────────────────────────────────
# flutter run --dart-define=API_BASE_URL=<değer> ile geçirilir
FRONTEND_API_BASE_URL=http://localhost:8080

# ── JWT (backend) ─────────────────────────────────────────────────────────
# TODO: Üretimde güçlü, rastgele bir secret kullanın (en az 256 bit)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000
