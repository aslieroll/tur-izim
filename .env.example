# Tur İzim — Ortam Değişkeni Şablonu
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin.
# .env dosyası .gitignore ile hariç tutulmuştur — asla Git'e eklemeyin.
#
# Kullanım (PowerShell):
#   cp .env.example .env
#   # .env dosyasını düzenleyin
#
# Kullanım (Docker Compose):
#   docker compose --env-file .env up -d

# ── Sunucu portu ──────────────────────────────────────────────────────────
# Railway/Heroku tarzı platformlar bunu otomatik verir; yerelde boş bırakın (8080).
PORT=

# ── PostgreSQL (yerel geliştirme) ─────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/turizim
POSTGRES_USER=turizim
POSTGRES_PASSWORD=

# ── PostgreSQL (deploy — standart Spring değişkenleri) ────────────────────
# Railway'de PostgreSQL eklentisinden alın; JDBC formatı zorunlu:
#   jdbc:postgresql://<host>:<port>/<database>
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────
# Dağıtılan frontend origin'i (örn. https://tur-izim.vercel.app).
# Virgülle birden fazla origin verilebilir. Boşsa yalnızca localhost açık.
FRONTEND_ORIGIN=

# ── Spring Boot uygulama ayarları ─────────────────────────────────────────
# Demo dağıtımı: ikisi de true (boş DB'ye demo veri + token'sız API erişimi).
# Gerçek üretim: ikisi de false yapın (JWT zorunlu olur; seed kapanır).
APP_DEV_SEED=true
APP_LEGACY_OPEN_API=true

# ── AI servisi (OpenRouter) ───────────────────────────────────────────────
# Anahtar boş bırakılabilir: backend deterministik fallback özet döner
# (fallbackUsed: true). Gerçek anahtar canlı LLM açıklaması açar.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Frontend / Flutter ────────────────────────────────────────────────────
# flutter build/run sırasında --dart-define=API_BASE_URL=<değer> ile geçirilir.
# Yerel varsayılan: http://localhost:8080
# Üretim örneği: https://<railway-backend-domain>
API_BASE_URL=http://localhost:8080
FRONTEND_API_BASE_URL=http://localhost:8080

# ── Harici ödeme linkleri (backend env, frontend'e geçirilmez) ───────────────
# Boş bırakılırsa /api/billing/agency/checkout 422 döner; frontend güvenli mesaj gösterir.
# Uygulama içinde kart işleme yapılmaz, kart verisi saklanmaz.
AGENCY_PRO_PAYMENT_LINK=
AGENCY_GROWTH_PAYMENT_LINK=

# ── JWT (backend) ─────────────────────────────────────────────────────────
# Üretimde güçlü, rastgele bir secret kullanın (en az 256 bit).
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ── İlk ADMIN bootstrap (üretim/beta, tek seferlik) ───────────────────────
# Genel admin kayıt API'si yoktur; ilk ADMIN bu env ile startup'ta oluşturulur.
# Bir kez deploy + giriş doğrulandıktan sonra APP_ADMIN_BOOTSTRAP_ENABLED=false yapın.
# Gerçek e-posta/şifreyi asla repoya yazmayın; yalnızca Railway env'de tutun.
APP_ADMIN_BOOTSTRAP_ENABLED=false
APP_ADMIN_EMAIL=
APP_ADMIN_PASSWORD=
